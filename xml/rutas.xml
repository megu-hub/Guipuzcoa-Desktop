  <!-- ==================== RUTA 3 ==================== -->
  <ruta id="R003">
    <nombre>Ruta del Camino de Santiago del Norte por Gipuzkoa</nombre>
    <tipo>Senderismo</tipo>
    <medioTransporte>A pie</medioTransporte>
    <fechaInicio opcional="true">2025-09-01</fechaInicio>
    <horaInicio opcional="true">07:30</horaInicio>
    <duracion>3 días</duracion>
    <agencia>Camino del Norte Gipuzkoa</agencia>
    <descripcion>Tramo guipuzcoano del Camino de Santiago del Norte, desde Irún hasta Deba (~85 km). Acantilados, rías, bosques atlánticos y caseríos vascos. Itinerario Cultural Europeo del Consejo de Europa.</descripcion>
    <personasAdecuadas>Personas en forma física moderada; no recomendada para niños menores de 12 años sin preparación previa</personasAdecuadas>
    <lugarInicio>Puente Internacional de Behobia</lugarInicio>
    <direccionInicio>Puente de Behobia, Irún</direccionInicio>
    <coordenadasInicio>
      <longitud>-1.7742</longitud>
      <latitud>43.3471</latitud>
      <altitud>10</altitud>
    </coordenadasInicio>
    <referencias>
      <referencia id="R003-ref1">https://www.gronze.com/camino-norte/etapas/gipuzkoa</referencia>
      <referencia id="R003-ref2">https://es.wikipedia.org/wiki/Camino_del_Norte</referencia>
      <referencia id="R003-ref3">https://www.caminodesantiago.gal/es/rutas/camino-del-norte</referencia>
      <referencia id="R003-ref4">https://www.turismogipuzkoa.eus/es/camino-santiago</referencia>
    </referencias>
    <recomendacion>8</recomendacion>

    <hitos>
      <hito id="H003-01">
        <nombre>Puente Internacional de Behobia (Irún)</nombre>
        <descripcion>Inicio del Camino del Norte en España. El puente une Irún con Hendaya (Francia) por el río Bidasoa. Ermita de San Marcial como primer hito espiritual, con vistas a la bahía de Txingudi.</descripcion>
        <coordenadas>
          <longitud>-1.7742</longitud>
          <latitud>43.3471</latitud>
          <altitud>10</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="km">0</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Puente Internacional de Behobia sobre el río Bidasoa, inicio del Camino del Norte">../multimedia/R003/H003-01_behobia_puente.jpg</foto>
          <foto alt="Vista de la bahía de Txingudi desde las inmediaciones del Puente de Behobia">../multimedia/R003/H003-01_txingudi_bahia.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Vídeo del inicio del Camino del Norte desde el Puente de Behobia en Irún">../multimedia/R003/H003-01_inicio_camino.mp4</video>
        </galeriaVideos>
      </hito>

      <hito id="H003-02">
        <nombre>Casco histórico de Hondarribia</nombre>
        <descripcion>Villa medieval amurallada declarada Conjunto Monumental. Murallas del siglo XV, Castillo de Carlos V (Parador Nacional) y barrio de la Marina con casas porticadas de colores. Escenario de los Sitios de los siglos XVII-XVIII.</descripcion>
        <coordenadas>
          <longitud>-1.7975</longitud>
          <latitud>43.3648</latitud>
          <altitud>25</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="km">4.5</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Murallas medievales del siglo XV de Hondarribia bien conservadas">../multimedia/R003/H003-02_hondarribia_murallas.jpg</foto>
          <foto alt="Casas porticadas de colores del barrio de la Marina de Hondarribia">../multimedia/R003/H003-02_hondarribia_marina.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Vídeo de visita al casco histórico medieval de Hondarribia">../multimedia/R003/H003-02_hondarribia_visita.mp4</video>
        </galeriaVideos>
      </hito>

      <hito id="H003-03">
        <nombre>Monte Jaizkibel y Santuario de la Virgen de Guadalupe</nombre>
        <descripcion>Monte litoral más alto de la costa vasca (547 m). Vistas del Cantábrico, los Pirineos y la costa francesa. Santuario de Guadalupe (s. XVI), tradicional punto de descanso jacobeo.</descripcion>
        <coordenadas>
          <longitud>-1.8524</longitud>
          <latitud>43.3715</latitud>
          <altitud>450</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="km">8.2</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Panorámica del Mar Cantábrico desde la cima del Monte Jaizkibel">../multimedia/R003/H003-03_jaizkibel_panoramica.jpg</foto>
          <foto alt="Santuario de la Virgen de Guadalupe en las laderas del Monte Jaizkibel">../multimedia/R003/H003-03_jaizkibel_santuario.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Vídeo de dron sobrevolando la costa del Monte Jaizkibel">../multimedia/R003/H003-03_jaizkibel_drone.mp4</video>
        </galeriaVideos>
      </hito>

      <hito id="H003-04">
        <nombre>Pasajes de San Juan (Pasaia Donibane)</nombre>
        <descripcion>Pueblo de pescadores en la ría de Pasaia. Se cruza en barca de remo (rito del Camino). Víctor Hugo vivió aquí en 1843. Paseo marítimo único entre casas de piedra reflejadas en el agua.</descripcion>
        <coordenadas>
          <longitud>-1.9262</longitud>
          <latitud>43.3398</latitud>
          <altitud>5</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="km">12.3</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Casas de colores de Pasajes de San Juan reflejadas en las aguas de la ría">../multimedia/R003/H003-04_pasaia_casas.jpg</foto>
          <foto alt="Travesía en barca de remo para cruzar la ría de Pasaia en el Camino del Norte">../multimedia/R003/H003-04_pasaia_barca.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Vídeo de la travesía en barca sobre la ría de Pasaia en el Camino del Norte">../multimedia/R003/H003-04_pasaia_travesia.mp4</video>
        </galeriaVideos>
      </hito>

      <hito id="H003-05">
        <nombre>Zarautz — Playa y casco urbano</nombre>
        <descripcion>Playa más larga de Gipuzkoa (2,5 km). Capital del surf vasco, sede del World Surf League. Casco urbano con Torre Luzea y Palacio de Narros renacentistas. Excelente oferta de pintxos.</descripcion>
        <coordenadas>
          <longitud>-2.1711</longitud>
          <latitud>43.2843</latitud>
          <altitud>3</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="km">28.5</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Vista aérea de la playa de Zarautz, la más larga de Gipuzkoa, con surfistas">../multimedia/R003/H003-05_zarautz_playa.jpg</foto>
          <foto alt="Torre Luzea, edificio renacentista emblema del casco histórico de Zarautz">../multimedia/R003/H003-05_zarautz_torre_luzea.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Vídeo del campeonato de surf del World Surf League en la playa de Zarautz">../multimedia/R003/H003-05_zarautz_surf.mp4</video>
        </galeriaVideos>
      </hito>

      <hito id="H003-06">
        <nombre>Deba — Colegiata de Santa María</nombre>
        <descripcion>Punto final del tramo guipuzcoano. Colegiata gótica de Santa María (ss. XIV-XV) con portada esculpida y claustro elegante. La villa conserva su trazado medieval con calles porticadas y palacios renacentistas.</descripcion>
        <coordenadas>
          <longitud>-2.3521</longitud>
          <latitud>43.2955</latitud>
          <altitud>8</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="km">22.1</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Portada gótica esculpida de la Colegiata de Santa María de Deba">../multimedia/R003/H003-06_deba_portada.jpg</foto>
          <foto alt="Casco medieval de Deba con sus calles porticadas y arquitectura histórica">../multimedia/R003/H003-06_deba_casco.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Vídeo de visita al interior de la Colegiata de Santa María de Deba">../multimedia/R003/H003-06_deba_interior.mp4</video>
        </galeriaVideos>
      </hito>
    </hitos>

