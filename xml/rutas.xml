  <!-- ==================== RUTA 2 ==================== -->
  <ruta id="R002">
    <nombre>Ruta de Pintxos y Monumentos por la Parte Vieja de Donostia</nombre>
    <tipo>Mixta tapas y monumentos</tipo>
    <medioTransporte>A pie</medioTransporte>
    <fechaInicio opcional="true">2025-07-20</fechaInicio>
    <horaInicio opcional="true">11:00</horaInicio>
    <duracion>4 horas</duracion>
    <agencia>Donostia San Sebastián Turismoa</agencia>
    <descripcion>Recorrido por la Parte Vieja de San Sebastián que combina arquitectura histórica con la cultura del pintxo vasco, terminando con las vistas de La Concha desde el Monte Urgull.</descripcion>
    <personasAdecuadas>Todos los públicos, familias con niños, tercera edad, grupos de amigos</personasAdecuadas>
    <lugarInicio>Plaza de la Constitución</lugarInicio>
    <direccionInicio>Plaza de la Constitución s/n, Donostia-San Sebastián</direccionInicio>
    <coordenadasInicio>
      <longitud>-1.9762</longitud>
      <latitud>43.3228</latitud>
      <altitud>7</altitud>
    </coordenadasInicio>
    <referencias>
      <referencia id="R002-ref1">https://www.sansebastianturismo.com/es/que-ver/parte-vieja</referencia>
      <referencia id="R002-ref2">https://es.wikipedia.org/wiki/Parte_Vieja_de_San_Sebasti%C3%A1n</referencia>
      <referencia id="R002-ref3">https://www.euskaditurismo.net/es/donostia-gastronomia</referencia>
      <referencia id="R002-ref4">https://www.thefork.es/guia-restaurantes/san-sebastian-pintxos</referencia>
    </referencias>
    <recomendacion>10</recomendacion>

    <hitos>
      <hito id="H002-01">
        <nombre>Plaza de la Constitución</nombre>
        <descripcion>Corazón histórico de la Parte Vieja. Plaza porticada del siglo XIX, antigua plaza de toros. Los números en los balcones eran palcos de alquiler. Epicentro de la vida social donostiarra.</descripcion>
        <coordenadas>
          <longitud>-1.9762</longitud>
          <latitud>43.3228</latitud>
          <altitud>7</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="km">0</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Vista panorámica de la Plaza de la Constitución de San Sebastián con sus pórticos">../multimedia/R002/H002-01_plaza_panoramica.jpg</foto>
          <foto alt="Pórticos y bares de la Plaza de la Constitución iluminados de noche">../multimedia/R002/H002-01_plaza_noche.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Vídeo del ambiente veraniego en la Plaza de la Constitución durante la Semana Grande">../multimedia/R002/H002-01_plaza_ambiente.mp4</video>
        </galeriaVideos>
      </hito>

      <hito id="H002-02">
        <nombre>Basílica de Santa María del Coro</nombre>
        <descripcion>Joya del barroco vasco (1743-1774). Fachada churrigueresca de dos torres. Patrona de San Sebastián. Alberga obras de arte entre ellas un Cristo atribuido al círculo de Gregorio Fernández.</descripcion>
        <coordenadas>
          <longitud>-1.9754</longitud>
          <latitud>43.3221</latitud>
          <altitud>8</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="m">150</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Fachada barroca churrigueresca de la Basílica de Santa María del Coro en Donostia">../multimedia/R002/H002-02_basilica_fachada.jpg</foto>
          <foto alt="Interior y altar mayor de la Basílica de Santa María del Coro">../multimedia/R002/H002-02_basilica_interior.jpg</foto>
        </galeriaFotos>
      </hito>

      <hito id="H002-03">
        <nombre>Calle 31 de Agosto — Zona de Pintxos</nombre>
        <descripcion>Calle más célebre de la Parte Vieja y epicentro mundial del pintxo. Bares premiados como La Cuchara de San Telmo, Borda Berri y Bar Zeruko. Txangurro, foie micuit y pintxo de autor.</descripcion>
        <coordenadas>
          <longitud>-1.9768</longitud>
          <latitud>43.3232</latitud>
          <altitud>7</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="m">200</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Bares de pintxos alineados en la Calle 31 de Agosto de San Sebastián">../multimedia/R002/H002-03_calle31_bares.jpg</foto>
          <foto alt="Barra repleta de pintxos variados en un bar de la Calle 31 de Agosto">../multimedia/R002/H002-03_calle31_barra.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Vídeo del animado ambiente de tarde en los bares de pintxos de Donostia">../multimedia/R002/H002-03_calle31_ambiente.mp4</video>
        </galeriaVideos>
      </hito>

      <hito id="H002-04">
        <nombre>Mercado de La Bretxa</nombre>
        <descripcion>Mercado tradicional renovado en 2001. Pescados del Cantábrico, verduras de Tolosa, queso idiazabal y alubias de Tolosa. Historia que se remonta al siglo XIV, antiguo mercado extramuros.</descripcion>
        <coordenadas>
          <longitud>-1.9790</longitud>
          <latitud>43.3245</latitud>
          <altitud>6</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="m">350</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Puestos de pescado fresco del Cantábrico en el Mercado de La Bretxa">../multimedia/R002/H002-04_bretxa_pescado.jpg</foto>
          <foto alt="Ruedas de queso idiazabal de pastor en el Mercado de La Bretxa">../multimedia/R002/H002-04_bretxa_idiazabal.jpg</foto>
        </galeriaFotos>
      </hito>

      <hito id="H002-05">
        <nombre>Castillo de La Mota — Monte Urgull</nombre>
        <descripcion>Fortaleza medieval del siglo XII que corona el Monte Urgull. Mejores vistas panorámicas de San Sebastián: La Concha, isla de Santa Clara y Monte Igueldo. Estatua del Sagrado Corazón de 12 metros.</descripcion>
        <coordenadas>
          <longitud>-1.9718</longitud>
          <latitud>43.3262</latitud>
          <altitud>123</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="m">700</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Vista del Castillo de La Mota en la cima del Monte Urgull de San Sebastián">../multimedia/R002/H002-05_urgull_castillo.jpg</foto>
          <foto alt="Panorámica de la Bahía de La Concha desde las murallas del Monte Urgull">../multimedia/R002/H002-05_urgull_bahia.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Vídeo panorámica 360 grados desde la cima del Monte Urgull de San Sebastián">../multimedia/R002/H002-05_urgull_panoramica360.mp4</video>
        </galeriaVideos>
      </hito>

      <hito id="H002-06">
        <nombre>Playa de La Concha</nombre>
        <descripcion>Una de las playas urbanas más bellas de Europa. Bahía en forma de concha con el Palacio de Miramar y la isla de Santa Clara. Hasta 30.000 bañistas diarios en verano. Cierre espectacular del recorrido.</descripcion>
        <coordenadas>
          <longitud>-1.9843</longitud>
          <latitud>43.3189</latitud>
          <altitud>1</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="m">900</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Vista aérea de la Bahía de La Concha de San Sebastián con la isla de Santa Clara">../multimedia/R002/H002-06_concha_aerea.jpg</foto>
          <foto alt="Atardecer sobre la Bahía de La Concha con la isla de Santa Clara">../multimedia/R002/H002-06_concha_atardecer.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Vídeo de dron sobrevolando la Playa de La Concha en verano">../multimedia/R002/H002-06_concha_drone.mp4</video>
        </galeriaVideos>
      </hito>
    </hitos>

