    provincia   CDATA   #REQUIRED
    pais        CDATA   #REQUIRED
    region      CDATA   #REQUIRED
>
<!ELEMENT ruta (nombre, tipo, medioTransporte, fechaInicio?, horaInicio?,
                duracion, agencia, descripcion, personasAdecuadas,
                lugarInicio, direccionInicio, coordenadasInicio,
                referencias, recomendacion, hitos, puntosRuta,
                planimetria, altimetria)>
<!ATTLIST ruta
    id  ID  #REQUIRED
>
<!ELEMENT nombre            (#PCDATA)>
<!ELEMENT tipo              (#PCDATA)>
<!ELEMENT medioTransporte   (#PCDATA)>
<!ELEMENT duracion          (#PCDATA)>
<!ELEMENT agencia           (#PCDATA)>
<!ELEMENT descripcion       (#PCDATA)>
<!ELEMENT personasAdecuadas (#PCDATA)>
<!ELEMENT lugarInicio       (#PCDATA)>
<!ELEMENT direccionInicio   (#PCDATA)>
<!ELEMENT recomendacion     (#PCDATA)>
<!ELEMENT planimetria       (#PCDATA)>
<!ELEMENT altimetria        (#PCDATA)>
<!ELEMENT fechaInicio (#PCDATA)>
<!ATTLIST fechaInicio
    opcional (true|false) "true"
>
<!ELEMENT horaInicio (#PCDATA)>
<!ATTLIST horaInicio
    opcional (true|false) "true"
>
<!ELEMENT coordenadasInicio (longitud, latitud, altitud)>
<!ELEMENT coordenadas       (longitud, latitud, altitud)>
<!ELEMENT longitud  (#PCDATA)>
<!ELEMENT latitud   (#PCDATA)>
<!ELEMENT altitud   (#PCDATA)>
<!ELEMENT referencias (referencia, referencia, referencia, referencia*)>
<!ELEMENT referencia (#PCDATA)>
<!ATTLIST referencia
    id CDATA #REQUIRED
>
<!ELEMENT hitos (hito, hito, hito, hito, hito, hito*)>
<!ELEMENT hito  (nombre, descripcion, coordenadas,
                 distanciaDesdeAnterior, galeriaFotos, galeriaVideos?)>
<!ATTLIST hito
    id  ID  #REQUIRED
>
<!ELEMENT distanciaDesdeAnterior (#PCDATA)>
<!ATTLIST distanciaDesdeAnterior
    unidades (km|m|mi) #REQUIRED
>
<!ELEMENT galeriaFotos (foto, foto?, foto?, foto?, foto?)>
<!ELEMENT foto (#PCDATA)>
<!ATTLIST foto
    alt CDATA #REQUIRED
>
<!ELEMENT galeriaVideos (video, video?, video?)>
<!ELEMENT video (#PCDATA)>
<!ATTLIST video
    alt CDATA #REQUIRED
>
<!ELEMENT puntosRuta (punto+)>
<!ELEMENT punto EMPTY>
<!ATTLIST punto
    longitud    CDATA   #REQUIRED
    latitud     CDATA   #REQUIRED
    altitud     CDATA   #IMPLIED
>
]>

<rutas provincia="Gipuzkoa" pais="España" region="País Vasco">

  <!-- ==================== RUTA 1 ==================== -->
  <ruta id="R001">
    <nombre>Ruta de la Costa Vasca: De Getaria a Zumaia</nombre>
    <tipo>Paisajística</tipo>
    <medioTransporte>A pie</medioTransporte>
    <fechaInicio opcional="true">2025-06-15</fechaInicio>
    <horaInicio opcional="true">09:00</horaInicio>
    <duracion>1 día</duracion>
    <agencia>Geoparke Euskal Kostaldea</agencia>
    <descripcion>Recorrido a pie por los acantilados y playas de la costa guipuzcoana, desde Getaria hasta Zumaia, atravesando el Geoparque Mundial UNESCO del Flysch.</descripcion>
    <personasAdecuadas>Personas en buena forma física; no recomendada para tercera edad ni niños menores de 10 años</personasAdecuadas>
    <lugarInicio>Puerto de Getaria</lugarInicio>
    <direccionInicio>Calle Nagusia 1, Getaria</direccionInicio>
    <coordenadasInicio>
      <longitud>-2.2028</longitud>
      <latitud>43.3001</latitud>
      <altitud>5</altitud>
    </coordenadasInicio>
    <referencias>
      <referencia id="R001-ref1">https://www.turismogipuzkoa.eus/es/costa-vasca</referencia>
      <referencia id="R001-ref2">https://es.wikipedia.org/wiki/Flysch_de_Zumaia</referencia>
      <referencia id="R001-ref3">https://www.geoparkevasco.eus/es/rutas/costa</referencia>
      <referencia id="R001-ref4">https://www.wikiloc.com/rutas-senderismo/getaria-zumaia-costa</referencia>
    </referencias>
    <recomendacion>9</recomendacion>

    <hitos>
      <hito id="H001-01">
        <nombre>Puerto pesquero de Getaria</nombre>
        <descripcion>Punto de partida. Puerto pintoresco con flota pesquera activa. Frente a él se alza la isla de San Antón (el Ratón de Getaria). Cuna de Juan Sebastián Elcano y Cristóbal Balenciaga.</descripcion>
        <coordenadas>
          <longitud>-2.2028</longitud>
          <latitud>43.3001</latitud>
          <altitud>5</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="km">0</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Vista panorámica del puerto de Getaria con barcos pesqueros">../multimedia/R001/H001-01_puerto_panoramica.jpg</foto>
          <foto alt="Isla de San Antón (el Ratón) vista desde el puerto de Getaria">../multimedia/R001/H001-01_isla_raton.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Vídeo del amanecer en el puerto de Getaria con actividad pesquera">../multimedia/R001/H001-01_puerto_amanecer.mp4</video>
        </galeriaVideos>
      </hito>

      <hito id="H001-02">
        <nombre>Museo Cristóbal Balenciaga</nombre>
        <descripcion>Museo dedicado al modisto nacido en Getaria en 1895. El edificio combina palacio histórico y volumen de cristal contemporáneo. Más de 1.200 piezas originales del diseñador.</descripcion>
        <coordenadas>
          <longitud>-2.2041</longitud>
          <latitud>43.3010</latitud>
          <altitud>12</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="m">250</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Fachada exterior del Museo Balenciaga con su volumen de cristal contemporáneo">../multimedia/R001/H001-02_museo_fachada.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Vídeo de visita virtual a las salas del Museo Cristóbal Balenciaga">../multimedia/R001/H001-02_museo_visita_virtual.mp4</video>
        </galeriaVideos>
      </hito>

      <hito id="H001-03">
        <nombre>Playa de Malkorbe</nombre>
        <descripcion>Playa virgen de acceso difícil entre Getaria y Zumaia. Arenas doradas rodeadas de acantilados. Zona de especial protección medioambiental con avistamiento de aves marinas.</descripcion>
        <coordenadas>
          <longitud>-2.2280</longitud>
          <latitud>43.2967</latitud>
          <altitud>3</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="km">2.8</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Vista aérea de la playa virgen de Malkorbe rodeada de acantilados">../multimedia/R001/H001-03_malkorbe_aerea.jpg</foto>
          <foto alt="Acantilados que flanquean la playa de Malkorbe en la costa vasca">../multimedia/R001/H001-03_malkorbe_acantilados.jpg</foto>
        </galeriaFotos>
      </hito>

      <hito id="H001-04">
        <nombre>Acantilados del Flysch de Zumaia</nombre>
        <descripcion>Acantilados con sección estratigráfica continua de 50 millones de años. Geoparque Mundial UNESCO desde 2015. Sus estratos muestran el límite K-Pg relacionado con la extinción de los dinosaurios.</descripcion>
        <coordenadas>
          <longitud>-2.2500</longitud>
          <latitud>43.2920</latitud>
          <altitud>80</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="km">2.1</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Estratos verticales del flysch de Zumaia mostrando millones de años de historia geológica">../multimedia/R001/H001-04_flysch_estratos.jpg</foto>
          <foto alt="Panorámica aérea de los acantilados del Geoparque del Flysch de Zumaia">../multimedia/R001/H001-04_flysch_panoramica.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Documental geológico sobre la formación y significado del flysch de Zumaia">../multimedia/R001/H001-04_flysch_documental.mp4</video>
        </galeriaVideos>
      </hito>

      <hito id="H001-05">
        <nombre>Playa de Itzurun</nombre>
        <descripcion>Playa espectacular flanqueada por acantilados de flysch. Escenario de rodaje de Juego de Tronos (Rocadragón). Permite apreciar de cerca las formaciones rocosas del Geoparque.</descripcion>
        <coordenadas>
          <longitud>-2.2549</longitud>
          <latitud>43.2887</latitud>
          <altitud>2</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="m">800</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Playa de Itzurun con los impresionantes acantilados de flysch al fondo">../multimedia/R001/H001-05_itzurun_playa.jpg</foto>
          <foto alt="Atardecer sobre la playa de Itzurun y los acantilados de Zumaia">../multimedia/R001/H001-05_itzurun_atardecer.jpg</foto>
        </galeriaFotos>
        <galeriaVideos>
          <video alt="Vídeo de dron sobrevolando la playa de Itzurun y los acantilados de flysch">../multimedia/R001/H001-05_itzurun_drone.mp4</video>
        </galeriaVideos>
      </hito>

      <hito id="H001-06">
        <nombre>Centro de Interpretación Algorri (Zumaia)</nombre>
        <descripcion>Centro geológico del Geoparque en el casco histórico de Zumaia. Exposiciones interactivas sobre el flysch. Punto final de la ruta, en una antigua estructura portuaria rehabilitada.</descripcion>
        <coordenadas>
          <longitud>-2.2561</longitud>
          <latitud>43.2895</latitud>
          <altitud>10</altitud>
        </coordenadas>
        <distanciaDesdeAnterior unidades="m">500</distanciaDesdeAnterior>
        <galeriaFotos>
          <foto alt="Exterior del Centro de Interpretación Algorri junto al puerto de Zumaia">../multimedia/R001/H001-06_algorri_exterior.jpg</foto>
          <foto alt="Sala de exposición interactiva del Centro Algorri sobre geología del flysch">../multimedia/R001/H001-06_algorri_interior.jpg</foto>
        </galeriaFotos>
      </hito>
    </hitos>

